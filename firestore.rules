/**
 * @fileoverview Firestore Security Rules for Huxleigh AI.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for training sessions,
 * allowing users to manage only their own training data. Other data like blog posts,
 * authors, and clients are publicly readable but can only be modified by authenticated users.
 *
 * Data Structure:
 * - /blog_posts/{blogPostId}: Publicly readable blog posts, linked to authors.
 * - /authors/{authorId}: Publicly readable author profiles.
 * - /tags/{tagId}: Publicly readable tags for categorizing blog posts.
 * - /client_success_stories/{clientSuccessStoryId}: Publicly readable client success stories.
 * - /clients/{clientId}: Publicly readable client information.
 * - /inquiries/{inquiryId}: Customer inquiries (access needs to be defined and protected if needed).
 * - /ai_article_summaries/{aiArticleSummaryId}: Publicly readable AI article summaries.
 * - /hyperlinks/{hyperlinkId}: Hyperlink resources created by staff.
 * - /users/{userId}/trainingSessions/{sessionId}: Training sessions owned by a specific user.
 *
 * Key Security Decisions:
 * - Public read access for blog posts, authors, client stories, clients, and AI article summaries.
 * - Strict user-ownership for training sessions.
 * - Inquiries' security is TBD, currently open, will need review for production to enforce admin access.
 * - Hyperlinks' creator can update and delete the links.
 *
 * Denormalization for Authorization:
 * - Training sessions are nested under the user's ID to simplify ownership checks.
 *   This avoids the need for complex queries or `get()` calls to verify ownership.
 *
 * Structural Segregation:
 * - User-specific training data is stored in a private subcollection (/users/{userId}/trainingSessions/{sessionId}),
 *   while public content (blog posts, etc.) resides in top-level collections.
 *   This segregation improves security and performance for list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    /**
     * @description Allows public read access to blog posts. Only authenticated users can create, update, or delete blog posts.
     * @path /blog_posts/{blogPostId}
     * @allow (get, list): Public access to read blog posts.
     * @allow (create): Authenticated user can create a blog post. The 'authorId' must match the user's UID.
     * @allow (update, delete): Authenticated user can update/delete a blog post if they are the author.
     * @deny create: if request.resource.data.authorId != request.auth.uid;
     * @deny update: if resource.data.authorId != request.auth.uid;
     * @principle Allows public reads but protects write operations using ownership.
     */
    match /blog_posts/{blogPostId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.authorId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Allows public read access to author profiles. Only authenticated users can create, update, or delete author profiles.
     * @path /authors/{authorId}
     * @allow (get, list): Public access to read author profiles.
     * @allow (create): Authenticated user can create an author profile where the document ID matches their UID.
     * @allow (update, delete): Authenticated user can update/delete their own author profile.
     * @deny create: if request.resource.data.id != request.auth.uid;
     * @deny update: if resource.data.id != request.auth.uid;
     * @principle Enforces document ownership and allows self-creation of author profiles.
     */
    match /authors/{authorId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(authorId);
      allow delete: if isSignedIn() && isExistingOwner(authorId);
    }

    /**
     * @description Allows public read access to tags. Only authenticated users can create, update, or delete tags.
     * @path /tags/{tagId}
     * @allow (get, list): Public access to read tags.
     * @allow (create): Authenticated user can create a tag.
     * @allow (update, delete): Authenticated user can update/delete a tag.
     */
    match /tags/{tagId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows public read access to client success stories. Only authenticated users can create, update, or delete client success stories.
     * @path /client_success_stories/{clientSuccessStoryId}
     * @allow (get, list): Public access to read client success stories.
     * @allow (create): Authenticated user can create a client success story.
     * @allow (update, delete): Authenticated user can update/delete a client success story.
     */
    match /client_success_stories/{clientSuccessStoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows public read access to client information. Only authenticated users can create, update, or delete client information.
     * @path /clients/{clientId}
     * @allow (get, list): Public access to read client information.
     * @allow (create): Authenticated user can create a client.
     * @allow (update, delete): Authenticated user can update/delete a client.
     */
    match /clients/{clientId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows public read and write access to customer inquiries.  THIS SHOULD BE REVIEWED FOR PRODUCTION.
     * @path /inquiries/{inquiryId}
     * @allow (get, list, create, update, delete): Public access to read, list, create, update, and delete inquiries.
     */
    match /inquiries/{inquiryId} {
      allow get, list, create, update, delete: if true;
    }

    /**
     * @description Allows public read access to AI article summaries. Only authenticated users can create, update, or delete summaries.
     * @path /ai_article_summaries/{aiArticleSummaryId}
     * @allow (get, list): Public access to read AI article summaries.
     * @allow (create): Authenticated user can create an AI article summary.
     * @allow (update, delete): Authenticated user can update/delete an AI article summary.
     */
    match /ai_article_summaries/{aiArticleSummaryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    /**
     * @description Manages staff-created hyperlink resources.
     * @path /hyperlinks/{hyperlinkId}
     * @allow (get, list): Any authenticated user can read and list hyperlinks.
     * @allow (create): Only authenticated users can create hyperlinks, and the creatorId must match their UID.
     * @allow (update, delete): Only the creator of the hyperlink can update or delete it.
     * @deny create: if request.resource.data.creatorId != request.auth.uid;
     * @deny update: if resource.data.creatorId != request.auth.uid;
     * @deny delete: if resource.data.creatorId != request.auth.uid;
     * @principle Enforces ownership for hyperlink resources.
     */
    match /hyperlinks/{hyperlinkId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
        allow update: if isSignedIn() && isExistingOwner(resource.data.creatorId);
        allow delete: if isSignedIn() && isExistingOwner(resource.data.creatorId);
    }
    /**
     * @description Manages training sessions for users. Each user can only access their own training data.
     * @path /users/{userId}/trainingSessions/{sessionId}
     * @allow (get, list): Only the user can read their own training sessions.
     * @allow (create): Only the user can create training sessions under their ID, and the userId in the document must match their UID.
     * @allow (update, delete): Only the user can update or delete their own training sessions.
     * @deny create: if request.resource.data.userId != request.auth.uid;
     * @deny update: if resource.data.userId != request.auth.uid;
     * @principle Enforces strict user-ownership for training session data.
     */
    match /users/{userId}/trainingSessions/{sessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(userId) && resource.data.userId == request.auth.uid;
      allow delete: if isExistingOwner(userId) && resource.data.userId == request.auth.uid;
    }
  }
}